# Copy to .env and fill in. Loaded by scripts; never commit the real .env.

# Hugging Face token — required to download the *gated* SAM 3 checkpoints
# (request access at https://huggingface.co/facebook/sam3) and any HF assets.
HF_TOKEN=

# Where large artifacts live. Defaults (relative to repo root) are used if unset.
MOTION_CHECKPOINTS=checkpoints
MOTION_DATA=data
MOTION_OUTPUTS=outputs

# Force a device for model inference: cuda | mps | cpu | auto (default: auto)
MOTION_DEVICE=auto

# Path to the compiled locate-anything.cpp CLI (built by scripts/setup_mac.sh).
# If unset, motion looks for `locate-anything-cli` on PATH.
LOCATE_ANYTHING_CLI=
LOCATE_ANYTHING_GGUF=checkpoints/gguf/locate-anything-q8_0.gguf
